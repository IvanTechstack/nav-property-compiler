run = "python3 -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000"
modules = ["python-3.11"]

[agent]
expertMode = true

[nix]
packages = ["streamlit"]

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8501
externalPort = 80

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
