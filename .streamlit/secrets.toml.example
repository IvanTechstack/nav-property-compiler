# Copy this file's contents into the Streamlit Community Cloud
# Secrets manager (App Settings → Secrets) — do NOT commit real values.
#
# Path: App Settings → Secrets → paste the block below with real values filled in.

R2_ENDPOINT_URL = "https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID = "<your-r2-access-key-id>"
R2_SECRET_ACCESS_KEY = "<your-r2-secret-access-key>"
